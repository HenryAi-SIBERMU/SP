# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Project Info
PROJECT_NAME=Celios8-SolarPanel
PROJECT_PHASE=research

# Data Directories (relative to project root)
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_EXTERNAL_DIR=data/external
OUTPUT_DIR=output

# API Keys (if needed)
# GOOGLE_MAPS_API_KEY=your_key_here
# OPENWEATHER_API_KEY=your_key_here

# Database (if using database)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=celios8_solar
# DB_USER=your_username
# DB_PASSWORD=your_password

# PVGIS Settings
PVGIS_API_URL=https://re.jrc.ec.europa.eu/api/v5_2/PVcalc
PVGIS_DEFAULT_LAT=-6.2088
PVGIS_DEFAULT_LON=106.8456

# Solar Calculation Defaults
DEFAULT_KWP_PER_SQM=0.18
DEFAULT_USABLE_AREA_RATIO=0.75
DEFAULT_PEAK_SUN_HOURS=4.7
DEFAULT_PERFORMANCE_RATIO=0.77

# Financial Defaults (in IDR)
DEFAULT_CAPEX_PER_KWP=18000000
DEFAULT_ELECTRICITY_TARIFF=1467
DEFAULT_OPEX_PERCENT=0.02
DEFAULT_DISCOUNT_RATE=0.08
DEFAULT_LIFETIME_YEARS=25

# Visualization Settings
DEFAULT_MAP_CENTER_LAT=-6.2088
DEFAULT_MAP_CENTER_LON=106.8456
DEFAULT_MAP_ZOOM=11

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/celios8.log

# Development Settings
DEBUG=False
VERBOSE=False
